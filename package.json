{
  "name": "puzpuzpuz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:lint": "SUPABASE_ACCESS_TOKEN=local supabase db lint --local --level warning",
    "test": "npm run test:fe -- --run && npm run test:db",
    "test:fe": "vitest",
    "test:db": "supabase test db --local supabase/tests",
    "types:gen": "SUPABASE_ACCESS_TOKEN=local supabase gen types typescript --local > src/types/db.ts",
    "connections:import": "npx tsx supabase/scripts/import-connections-puzzles.ts",
    "spellingbee:import": "npx tsx supabase/scripts/import-spellingbee-pangrams.ts",
    "wordwheel:import": "npx tsx supabase/scripts/import-wordwheel-pangrams.ts",
    "words:import": "npx tsx supabase/scripts/import-words.ts",
    "boggle:wordlist": "npx tsx supabase/scripts/generate-boggle-wordlist.ts",
    "scrabble:wordlist": "npx tsx supabase/scripts/generate-scrabble-wordlist.ts",
    "scrabble:selfplay": "npx tsx supabase/scripts/scrabble-selfplay.ts",
    "stackdown:gen": "npx tsx supabase/scripts/generate-stackdown-boards.ts",
    "stackdown:import": "npx tsx supabase/scripts/import-stackdown-boards.ts",
    "crosswords:import": "npx tsx supabase/scripts/import-crosswords-puzzles.ts",
    "crosswords:puz-to-ipuz": "npx tsx supabase/scripts/crosswords/puz-to-ipuz.ts",
    "crosswords:set-note": "node supabase/scripts/crosswords/set-puz-note.mjs",
    "crosswords:make-fixture": "node supabase/scripts/crosswords/make-sunday-fixture.mjs",
    "import": "npm run words:import && npm run spellingbee:import && npm run wordwheel:import && npm run connections:import && npm run stackdown:import && npm run crosswords:import",
    "deploy": "npm run boggle:wordlist && npm run scrabble:wordlist && supabase db push && supabase functions deploy && npm run build && netlify deploy -p -d dist",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.22.0",
    "puzjs": "^1.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-rnd": "^10.5.3"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "pngjs": "^7.0.0",
    "postcss-custom-media": "^12.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
