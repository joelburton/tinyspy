# Test-mode env, loaded automatically by Vitest/Vite when mode === 'test'.
#
# The Vitest suite is stack-free — it mocks all network I/O — but the Supabase
# client module (src/common/lib/supabase/supabase.ts) throws at IMPORT time if
# these two vars are missing, so any test that transitively imports the client
# (e.g. the per-game PlayArea.test.tsx) fails to even collect without them.
# Locally they come from the gitignored .env.local; CI has no such file, so we
# commit these dummy loopback values here. They only need to be non-empty enough
# to construct a client — no real stack is contacted.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=test-anon-key
