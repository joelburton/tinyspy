{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  // These are node/filesystem tests (they read fixtures via `node:fs`) —
  // type-checked under tsconfig.node.json (which has node types) so the app
  // project stays browser-only and app code still can't import `fs` by
  // accident. cssTokens is a CSS meta-test; importFile reads .puz/.ipuz
  // fixtures to exercise the crosswords upload parser.
  "exclude": ["src/cssTokens.test.ts", "src/crosswords/lib/importFile.test.ts"]
}
