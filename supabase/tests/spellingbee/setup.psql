-- ============================================================
-- Per-test-file spellingbee fixtures
-- ============================================================
--
-- Loaded by every spellingbee/*_test.sql via:
--   \ir setup.psql
--
-- Provides:
--   pg_temp.spellingbee_board()       — Builds a valid `board` jsonb
--                                   (the shape spellingbee.create_game
--                                   accepts) suitable for tests.
--                                   30 required entries + 3 bonus
--                                   entries; all words use only
--                                   letters from the test puzzle
--                                   {a,b,c,d,e,f,g} with center 'e'.
--   pg_temp.spellingbee_setup()       — Builds a default coop `setup`
--                                   jsonb. Tests override via
--                                   `setup || jsonb_build_object(...)`
--                                   when they need a specific field
--                                   exercised.
--
-- The "test board" is deliberately small but valid:
--   - Letters: outer = 'abcdfg', center = 'e'.
--   - 28 four-letter entries (1pt each).
--   - 1 five-letter entry (5pt).
--   - 1 seven-letter pangram (5+10=17pt; synthetic — "abcdefg"
--     isn't an English word, but the create_game RPC doesn't
--     dictionary-check the wordlist content, just the structure).
--   - 3 bonus entries (legal − required).
-- Total required: 28 + 5 + 17 = 50 points across 30 words.
--
-- Rank thresholds for required_words_score=50:
--   Good   ≥ 6
--   Solid  ≥ 12
--   Nice   ≥ 18
--   Great  ≥ 24
--   Amazing ≥ 30
--   Genius ≥ 35
--
-- All "words" are letter-valid for the puzzle (use only
-- {a,b,c,d,e,f,g} and include 'e'), so submit_word will accept
-- every entry without hitting badLetters / missingCenter. Some
-- are real English (bead, beef, face, …), some are synthetic
-- (abce, acef, …). The synthetic ones earn the same points as
-- their length suggests — submit_word reads `points` directly
-- from the required_words entry, not from the dictionary.

create function pg_temp.spellingbee_board()
returns jsonb
language plpgsql
as $$
declare
  required jsonb := '[]'::jsonb;
  -- bonus holds the bonus set (legal − required), now the same
  -- { word, points, is_pangram } shape as required (the FE scores bonus words
  -- locally). 'gfedcba' is a synthetic 7-distinct-letter word covering the
  -- bonus-pangram path (length 7 + 10 pangram bonus = 17).
  bonus jsonb := jsonb_build_array(
    jsonb_build_object('word', 'bcdfge',  'points', 6,  'is_pangram', false),
    jsonb_build_object('word', 'abcdef',  'points', 6,  'is_pangram', false),
    jsonb_build_object('word', 'gfedcba', 'points', 17, 'is_pangram', true)
  );
  -- 28 four-letter + 1 five-letter + 1 seven-letter, in that order.
  syn_words text[] := array[
    'bead','beef','face','fade','cage','cafe','deaf','aged',
    'bade','feed','edge','abed','gabe','babe','dade','abef',
    'abeg','abce','acef','aceg','adef','adeg','afeg','bcef',
    'bceg','bdef','bdeg','bfeg',
    'faced',
    'abcdefg'
  ];
  w text;
  pt int;
  is_pang bool;
  total int := 0;
begin
  foreach w in array syn_words loop
    is_pang := (length(w) = 7);
    pt := case
            when length(w) = 4 then 1
            when is_pang then length(w) + 10  -- 7 + 10 pangram bonus
            else length(w)                    -- 5+: length-based
          end;
    required := required || jsonb_build_array(
      jsonb_build_object('word', w, 'points', pt, 'is_pangram', is_pang)
    );
    total := total + pt;
  end loop;
  return jsonb_build_object(
    'outer_letters',        'abcdfg',
    'center_letter',        'e',
    'required_words_score', total,
    'required_words_count', jsonb_array_length(required),
    'required_words',       required,
    'bonus_words',          bonus
  );
end;
$$;

-- Default setup: no timer. Mode is now a positional RPC arg
-- (sibling-manifest split — gametype string carries the mode);
-- the new spellingbee.create_game REJECTS a `mode` field on setup so
-- a stale FE fails fast. Tests that exercise compete-mode setup
-- shape (target_rank validation) override via jsonb concatenation:
--   pg_temp.spellingbee_setup() || '{"target_rank": 3}'::jsonb
-- and pass 'compete' as the create_game `mode` arg.

create function pg_temp.spellingbee_setup()
returns jsonb
language sql
as $$
  select jsonb_build_object(
    'timer', jsonb_build_object('kind', 'none')
  );
$$;
