-- ============================================================
-- Per-test-file waffle fixtures
-- ============================================================
--
-- Loaded by every waffle/*_test.sql via `\ir setup.psql` (after the
-- shared persona setup).
--
-- Provides:
--   - pg_temp.waffle_board() — a deterministic `board` jsonb in the
--     shape waffle.create_game accepts. The scramble is exactly ONE
--     swap (cells 0 and 1) away from solved, so a test can solve it
--     with submit_swap(game, 0, 1). The solution uses 21 distinct
--     letters (a..u) so there's no color/duplicate ambiguity, and its
--     holes sit at the four interior cells (it passes create_game's
--     structural checks). par_swaps = 1.
--   - pg_temp.waffle_setup(extra) — the coop setup jsonb. `extra` is
--     the swap-budget slack (max_swaps = par + extra); par is 1 here,
--     so extra=0 gives a 1-swap budget (handy for the lose path).
--
-- Boards are normally built on demand by the waffle-build-board edge
-- function; the tests pass this fixed board straight to create_game so
-- the RPC is exercised deterministically without the generator.

reset role;

create function pg_temp.waffle_board()
returns jsonb
language sql
as $$
  select jsonb_build_object(
    'solution',  'abcdef.g.hijklmn.o.pqrstu',  -- solved
    'scramble',  'bacdef.g.hijklmn.o.pqrstu',  -- cells 0,1 swapped → 1 swap away
    'par_swaps', 1
  );
$$;

create function pg_temp.waffle_setup(extra int default 5)
returns jsonb
language sql
as $$
  select jsonb_build_object(
    'difficulty', 2,
    'extra_swaps', extra,
    'timer', jsonb_build_object('kind', 'none')
  );
$$;
