-- ============================================================
-- Per-test-file stackdown fixtures
-- ============================================================
-- Loaded by every stackdown/*_test.sql via `\ir setup.psql` (after the
-- shared persona setup).
--
-- Inserts ONE known board into the library so create_game claims it
-- deterministically (the real game fills stackdown.boards via the offline
-- import; tests don't run that). A trap-free board generated against the
-- StackDown standard set — VULVA DOLED URNED YOKED BOOBY GRIPT — whose six
-- words are all in `common.words` at `difficulty = 1 AND american AND NOT
-- slur AND len = 5` (exactly what stackdown._is_word level 0 accepts).
--
-- Helpers:
--   pg_temp.sd_seq(n)  — the tile-id sequence (spelling order) that spells
--                        word n (1..6) on this board; tests play it out.
--   pg_temp.sd_invalid() — a reachable 5-tile sequence that spells a
--                        NON-word ("VEUVD"), for the invalid-word path.

reset role;

-- Clear any library boards first so create_game's `order by random()`
-- can ONLY pick our fixture. Without this, a dev/CI database that has
-- run `stackdown:import` would have real boards visible inside this
-- transaction, and create_game might claim one of those — making
-- sd_seq() (which encodes THIS board) spell the wrong tiles. The delete
-- is transactional and rolls back with the test; `on delete set null`
-- on games.board_id keeps it from tripping the FK.
delete from stackdown.boards;

insert into stackdown.boards (tiles, words) values (
  '[{"id":0,"z":0,"y":0,"x":2,"letter":"E"},{"id":1,"z":0,"y":0,"x":6,"letter":"D"},{"id":2,"z":1,"y":1,"x":3,"letter":"D"},{"id":3,"z":1,"y":1,"x":5,"letter":"A"},{"id":4,"z":0,"y":2,"x":0,"letter":"N"},{"id":5,"z":2,"y":2,"x":2,"letter":"E"},{"id":6,"z":2,"y":2,"x":4,"letter":"V"},{"id":7,"z":2,"y":2,"x":6,"letter":"L"},{"id":8,"z":0,"y":2,"x":8,"letter":"T"},{"id":9,"z":1,"y":3,"x":1,"letter":"R"},{"id":10,"z":3,"y":3,"x":3,"letter":"V"},{"id":11,"z":3,"y":3,"x":5,"letter":"U"},{"id":12,"z":1,"y":3,"x":7,"letter":"I"},{"id":13,"z":0,"y":4,"x":0,"letter":"B"},{"id":14,"z":2,"y":4,"x":2,"letter":"U"},{"id":15,"z":2,"y":4,"x":6,"letter":"Y"},{"id":16,"z":0,"y":4,"x":8,"letter":"P"},{"id":17,"z":1,"y":5,"x":1,"letter":"D"},{"id":18,"z":3,"y":5,"x":3,"letter":"O"},{"id":19,"z":3,"y":5,"x":5,"letter":"O"},{"id":20,"z":1,"y":5,"x":7,"letter":"G"},{"id":21,"z":0,"y":6,"x":0,"letter":"Y"},{"id":22,"z":2,"y":6,"x":2,"letter":"L"},{"id":23,"z":2,"y":6,"x":4,"letter":"K"},{"id":24,"z":2,"y":6,"x":6,"letter":"D"},{"id":25,"z":0,"y":6,"x":8,"letter":"R"},{"id":26,"z":1,"y":7,"x":3,"letter":"E"},{"id":27,"z":1,"y":7,"x":5,"letter":"B"},{"id":28,"z":0,"y":8,"x":2,"letter":"O"},{"id":29,"z":0,"y":8,"x":6,"letter":"O"}]'::jsonb,
  array['VULVA','DOLED','URNED','YOKED','BOOBY','GRIPT']
);

create function pg_temp.sd_seq(n int) returns int[] language sql as $$
  select case n
    when 1 then array[10,11,7,6,3]     -- VULVA
    when 2 then array[1,18,22,5,2]     -- DOLED
    when 3 then array[14,9,4,0,17]     -- URNED
    when 4 then array[21,19,23,26,24]  -- YOKED
    when 5 then array[27,28,29,13,15]  -- BOOBY
    when 6 then array[20,25,12,16,8]   -- GRIPT
  end;
$$;

create function pg_temp.sd_invalid() returns int[] language sql as $$
  select array[10,5,11,6,2];           -- reachable at start, spells VEUVD (not a word)
$$;
