-- ============================================================
-- Per-test-file stackdown fixtures
-- ============================================================
-- Loaded by every stackdown/*_test.sql via `\ir setup.psql` (after the
-- shared persona setup).
--
-- Inserts ONE known board into the library so create_game claims it
-- deterministically (the real game fills stackdown.boards via the offline
-- import; tests don't run that). A trap-free board whose six solution words
-- are deliberately ULTRA-common — EAGLE TABLE PLANS APPLE JUICE LEMON —
-- drawn from a curated pool, not a random difficulty-1 pick, so the fixture
-- survives the upstream re-banding of borderline words. All six are in
-- `common.words` at `difficulty = 1 AND american AND slur = 0 AND crude = 0 AND len = 5`
-- (the StackDown standard set the boards are generated against), and the
-- board is fork-free against that full set. Solution words are stored
-- LOWERCASE (the app convention); tile letters stay uppercase glyphs.
--
-- Helpers:
--   pg_temp.sd_seq(n)  — the tile-id sequence (spelling order) that spells
--                        word n (1..6) on this board; tests play it out.
--   pg_temp.sd_invalid() — a reachable 5-tile sequence that spells a
--                        NON-word ("EBATL"), for the invalid-word path.

reset role;

-- Clear any library boards first so create_game's `order by random()`
-- can ONLY pick our fixture. Without this, a dev/CI database that has
-- run `stackdown:import` would have real boards visible inside this
-- transaction, and create_game might claim one of those — making
-- sd_seq() (which encodes THIS board) spell the wrong tiles. The delete
-- is transactional and rolls back with the test; `on delete set null`
-- on games.board_id keeps it from tripping the FK.
delete from stackdown.boards;

insert into stackdown.boards (tiles, words) values (
  '[{"id":0,"z":0,"y":0,"x":2,"letter":"E"},{"id":1,"z":0,"y":0,"x":6,"letter":"A"},{"id":2,"z":1,"y":1,"x":3,"letter":"L"},{"id":3,"z":1,"y":1,"x":5,"letter":"N"},{"id":4,"z":0,"y":2,"x":0,"letter":"C"},{"id":5,"z":2,"y":2,"x":2,"letter":"B"},{"id":6,"z":2,"y":2,"x":4,"letter":"T"},{"id":7,"z":2,"y":2,"x":6,"letter":"P"},{"id":8,"z":0,"y":2,"x":8,"letter":"S"},{"id":9,"z":1,"y":3,"x":1,"letter":"E"},{"id":10,"z":3,"y":3,"x":3,"letter":"E"},{"id":11,"z":3,"y":3,"x":5,"letter":"A"},{"id":12,"z":1,"y":3,"x":7,"letter":"L"},{"id":13,"z":0,"y":4,"x":0,"letter":"N"},{"id":14,"z":2,"y":4,"x":2,"letter":"L"},{"id":15,"z":2,"y":4,"x":6,"letter":"G"},{"id":16,"z":0,"y":4,"x":8,"letter":"A"},{"id":17,"z":1,"y":5,"x":1,"letter":"L"},{"id":18,"z":3,"y":5,"x":3,"letter":"P"},{"id":19,"z":3,"y":5,"x":5,"letter":"E"},{"id":20,"z":1,"y":5,"x":7,"letter":"A"},{"id":21,"z":0,"y":6,"x":0,"letter":"E"},{"id":22,"z":2,"y":6,"x":2,"letter":"U"},{"id":23,"z":2,"y":6,"x":4,"letter":"J"},{"id":24,"z":2,"y":6,"x":6,"letter":"L"},{"id":25,"z":0,"y":6,"x":8,"letter":"P"},{"id":26,"z":1,"y":7,"x":3,"letter":"I"},{"id":27,"z":1,"y":7,"x":5,"letter":"M"},{"id":28,"z":0,"y":8,"x":2,"letter":"E"},{"id":29,"z":0,"y":8,"x":6,"letter":"O"}]'::jsonb,
  array['eagle','table','plans','apple','juice','lemon']
);

create function pg_temp.sd_seq(n int) returns int[] language sql as $$
  select case n
    when 1 then array[19,11,15,24,10]  -- EAGLE
    when 2 then array[6,20,5,2,0]      -- TABLE
    when 3 then array[7,12,16,3,8]     -- PLANS
    when 4 then array[1,18,25,14,9]    -- APPLE
    when 5 then array[23,22,26,4,28]   -- JUICE
    when 6 then array[17,21,27,29,13]  -- LEMON
  end;
$$;

create function pg_temp.sd_invalid() returns int[] language sql as $$
  select array[10,5,11,6,2];           -- reachable at start, spells EBATL (not a word)
$$;
