-- ============================================================
-- Shared test setup — personas + auth helper
-- ============================================================
--
-- Loaded at the top of every pgTAP test file via:
--
--   \ir ../_shared/setup.psql
--
-- (`\ir`, not `\i` — `\ir` resolves the path relative to the
-- *including file's* directory, so this single line works
-- whether the caller lives in tests/common/, tests/tinyspy/, or
-- tests/psychicnum/. With `\i`, the path would resolve relative
-- to psql's current working directory, which is brittle.)
--
-- What this file gives every test:
--   1. Five auth.users rows for the standard personas, with
--      common.profiles + solo clubs materialized by the
--      on_auth_user_created trigger.
--   2. pg_temp.as_user(uid) — switches the session to act as a
--      given authenticated user. Used by every test that needs
--      to invoke an RPC as a particular person.
--
-- Underneath each test still wraps in begin/rollback, so all
-- of the rows and the temp function created here are scoped to
-- the single test file. Nothing leaks across tests.
--
-- ============================================================
-- The personas — read this before writing or editing a test
-- ============================================================
--
-- Test fixtures are people, not row-numbers. The names below
-- have roles you should respect across the suite so a reader
-- can scan a test and know who's who without re-checking the
-- fixture block each time.
--
--   ada     The default test subject. When a test just needs
--           "some authenticated user is doing the thing," use
--           ada. She is always in the relevant club and, if a
--           game is in progress, she's playing it.
--
--   bea     The second player. Reach for bea when the test
--           needs two people interacting — ada gives a clue,
--           bea guesses; ada submits a guess, bea sees the
--           realtime update. Like ada, bea is always in the
--           club AND in any game being played.
--
--   cade    In the club, but not necessarily in the current
--           game. Use cade when the test specifically wants to
--           exercise "a club member who isn't part of this
--           particular game" — e.g., he walked into the club
--           room while ada + bea were mid-game, or he's the
--           third member of a 3-member club that's about to be
--           rejected by tinyspy.create_game (which requires
--           exactly 2 members).
--
--   dee     Outside the club entirely. dee is an existing
--           authenticated user — she signed in, so her profile
--           and solo club exist — but she's never a member of
--           the test's club. Use dee whenever the test needs
--           someone whose RPC calls should be rejected with
--           "not a member of this club", or whose SELECT should
--           return zero rows because of club-scoped RLS.
--
--   eda     A second outsider, for the rare test that needs
--           two non-members. Same role as dee, different person.
--
-- The mnemonic: ada/bea/cade are *inside* (alphabetically
-- adjacent, easy to bracket as "the in-club trio"); dee/eda are
-- *outside* (next two letters, the outside pair).
--
-- ============================================================
-- Fixtures
-- ============================================================
--
-- UUIDs embed the persona name in the first hex block, padded out
-- to 8 hex chars with the block's repeated digit. The pattern is
-- '<name><padding>-<N>-<N>-<N>-<N x 12>' where <N> is 1..5 for
-- ada/bea/cade/dee/eda respectively. So:
--
--   ada11111-1111-1111-1111-111111111111
--   bea22222-2222-2222-2222-222222222222
--   cade3333-3333-3333-3333-333333333333
--   dee44444-4444-4444-4444-444444444444
--   eda55555-5555-5555-5555-555555555555
--
-- The point is self-evidence. A failing test referencing
-- 'ada11111-...' immediately tells you ada is the actor, without
-- a "1111... is ada" sidecar mapping. The blocks after the first
-- are pure padding so the IDs stay valid UUID shape (8-4-4-4-12).

insert into auth.users (id, instance_id, aud, role, email, email_confirmed_at, created_at, updated_at) values
  ('ada11111-1111-1111-1111-111111111111', '00000000-0000-0000-0000-000000000000',
   'authenticated', 'authenticated', 'ada@test.local',  now(), now(), now()),
  ('bea22222-2222-2222-2222-222222222222', '00000000-0000-0000-0000-000000000000',
   'authenticated', 'authenticated', 'bea@test.local',  now(), now(), now()),
  ('cade3333-3333-3333-3333-333333333333', '00000000-0000-0000-0000-000000000000',
   'authenticated', 'authenticated', 'cade@test.local', now(), now(), now()),
  ('dee44444-4444-4444-4444-444444444444', '00000000-0000-0000-0000-000000000000',
   'authenticated', 'authenticated', 'dee@test.local',  now(), now(), now()),
  ('eda55555-5555-5555-5555-555555555555', '00000000-0000-0000-0000-000000000000',
   'authenticated', 'authenticated', 'eda@test.local',  now(), now(), now());

-- Manually materialize what common.claim_username would have
-- produced for each persona: a common.profiles row, a solo club
-- ('=<username>' handle), a clubs_members row joining the user
-- to their solo club, and a clubs_gametypes row per registered
-- gametype.
--
-- Why direct INSERTs instead of calling the RPC five times: the
-- RPC reads auth.uid() and runs SECURITY DEFINER, so we'd have
-- to as_user each persona, call claim_username, switch back.
-- Direct inserts as postgres-superuser are cleaner for fixtures
-- where we KNOW exactly what should land. The claim_username
-- RPC itself is exercised by tests/common/claim_username_test.sql
-- — that's where the end-to-end contract gets pinned.
--
-- Keep this in sync with the body of common.claim_username in
-- 20260615000000_common_baseline.sql. If the claim RPC starts
-- materializing more (say, a "welcome" chat message), this fixture
-- needs the same addition to keep tests representative.

insert into common.profiles (user_id, username, color) values
  ('ada11111-1111-1111-1111-111111111111', 'ada',  common.color_for_username('ada')),
  ('bea22222-2222-2222-2222-222222222222', 'bea',  common.color_for_username('bea')),
  ('cade3333-3333-3333-3333-333333333333', 'cade', common.color_for_username('cade')),
  ('dee44444-4444-4444-4444-444444444444', 'dee',  common.color_for_username('dee')),
  ('eda55555-5555-5555-5555-555555555555', 'eda',  common.color_for_username('eda'));

insert into common.clubs (handle, name, created_by) values
  ('=ada',  'ada',  'ada11111-1111-1111-1111-111111111111'),
  ('=bea',  'bea',  'bea22222-2222-2222-2222-222222222222'),
  ('=cade', 'cade', 'cade3333-3333-3333-3333-333333333333'),
  ('=dee',  'dee',  'dee44444-4444-4444-4444-444444444444'),
  ('=eda',  'eda',  'eda55555-5555-5555-5555-555555555555');

insert into common.clubs_members (club_handle, user_id) values
  ('=ada',  'ada11111-1111-1111-1111-111111111111'),
  ('=bea',  'bea22222-2222-2222-2222-222222222222'),
  ('=cade', 'cade3333-3333-3333-3333-333333333333'),
  ('=dee',  'dee44444-4444-4444-4444-444444444444'),
  ('=eda',  'eda55555-5555-5555-5555-555555555555');

insert into common.clubs_gametypes (club_handle, gametype)
  select c.handle, g.gametype
    from (values ('=ada'), ('=bea'), ('=cade'), ('=dee'), ('=eda')) as c(handle)
   cross join common.gametypes g;

-- ============================================================
-- pg_temp.as_user — switch the session to "I am this user"
-- ============================================================
--
-- pgTAP tests start out running as the postgres superuser
-- (which bypasses RLS). To exercise an RPC the way a real FE
-- call would, we need to flip the session into the
-- `authenticated` role and put the user's id into
-- request.jwt.claims (where auth.uid() reads from).
--
-- Each test calls `select pg_temp.as_user('11111111-...')`
-- before invoking an RPC that should run as ada. Switching to
-- a different person is just another as_user call; resetting
-- back to postgres (e.g. to read across RLS for an assertion)
-- is `reset role; select set_config('request.jwt.claims', '', true);`.

create function pg_temp.as_user(uid uuid) returns void
language plpgsql as $$
begin
  perform set_config('request.jwt.claims',
                     json_build_object('sub', uid::text, 'role', 'authenticated')::text,
                     true);
  perform set_config('role', 'authenticated', true);
end;
$$;
