-- ============================================================
-- Per-test-file scrabble fixtures / rigging helpers
-- ============================================================
-- Loaded by every scrabble/*_test.sql via `\ir setup.psql` (after the
-- shared persona setup).
--
-- scrabble deals racks + shuffles the bag RANDOMLY, so tests can't
-- predict what a player holds. These helpers (run as the postgres
-- superuser, bypassing RLS/grants) overwrite the relevant rack + bag with
-- KNOWN tiles so a test can drive a deterministic play. They're the
-- scrabble analogue of stackdown's `sd_seq` fixture.
--
-- The dictionary check in play_word reads the real common.words table
-- (populated by `words:import`, visible inside the test transaction), so
-- tests use real words ('AT', 'CAT', …) and a deliberate non-word for the
-- reject path.

reset role;

-- Coop: set the shared rack + remaining bag.
create function pg_temp.sc_coop(g uuid, p_rack text[], p_bag text[])
returns void language sql as $$
  update scrabble.games set shared_rack = p_rack, bag = p_bag where id = g;
$$;

-- Compete: set one player's rack.
create function pg_temp.sc_rack(g uuid, p_uid uuid, p_rack text[])
returns void language sql as $$
  update scrabble.players set rack = p_rack where game_id = g and user_id = p_uid;
$$;

-- Set the remaining bag (either mode).
create function pg_temp.sc_bag(g uuid, p_bag text[])
returns void language sql as $$
  update scrabble.games set bag = p_bag where id = g;
$$;

-- Force whose turn it is (compete) — by the user's SEAT (turns are seat-based).
create function pg_temp.sc_turn(g uuid, p_uid uuid)
returns void language sql as $$
  update scrabble.games
     set current_seat = (select seat from scrabble.players where game_id = g and user_id = p_uid)
   where id = g;
$$;

-- Force whose turn it is by seat directly (for AI seats, which have no user).
create function pg_temp.sc_turn_seat(g uuid, p_seat int)
returns void language sql as $$
  update scrabble.games set current_seat = p_seat where id = g;
$$;

-- The user whose turn it currently is (compete) — resolves current_seat back to
-- a user_id for the seat-based turn assertions. NULL if it's an AI seat's turn.
create function pg_temp.sc_current_user(g uuid)
returns uuid language sql as $$
  select p.user_id
    from scrabble.players p
    join scrabble.games gm on gm.id = p.game_id and gm.current_seat = p.seat
   where gm.id = g;
$$;
