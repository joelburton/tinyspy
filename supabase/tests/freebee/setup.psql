-- ============================================================
-- Per-test-file freebee fixtures
-- ============================================================
--
-- Loaded by every freebee/*_test.sql via:
--   \ir setup.psql
--
-- Provides:
--   pg_temp.freebee_board()       — Builds a valid `board` jsonb
--                                   (the shape freebee.create_game
--                                   accepts) suitable for tests.
--                                   30 scoring entries + 2 bonus
--                                   entries; all words use only
--                                   letters from the test puzzle
--                                   {a,b,c,d,e,f,g} with center 'e'.
--   pg_temp.freebee_setup()       — Builds a default coop `setup`
--                                   jsonb. Tests override via
--                                   `setup || jsonb_build_object(...)`
--                                   when they need a specific field
--                                   exercised.
--
-- The "test board" is deliberately small but valid:
--   - Letters: outer = 'abcdfg', center = 'e'.
--   - 28 four-letter entries (1pt each).
--   - 1 five-letter entry (5pt).
--   - 1 seven-letter pangram (5+10=17pt; synthetic — "abcdefg"
--     isn't an English word, but the create_game RPC doesn't
--     dictionary-check the wordlist content, just the structure).
--   - 2 bonus (legal-only) entries.
-- Total scoring: 28 + 5 + 17 = 50 points across 30 words.
--
-- Rank thresholds for total_score=50:
--   Good   ≥ 6
--   Solid  ≥ 12
--   Nice   ≥ 18
--   Great  ≥ 24
--   Amazing ≥ 30
--   Genius ≥ 35
--
-- All "words" are letter-valid for the puzzle (use only
-- {a,b,c,d,e,f,g} and include 'e'), so submit_word will accept
-- every entry without hitting badLetters / missingCenter. Some
-- are real English (bead, beef, face, …), some are synthetic
-- (abce, acef, …). The synthetic ones earn the same points as
-- their length suggests — submit_word reads `points` directly
-- from the scoring_words entry, not from the dictionary.

create function pg_temp.freebee_board()
returns jsonb
language plpgsql
as $$
declare
  scoring jsonb := '[]'::jsonb;
  legal jsonb := jsonb_build_array('bcdfge', 'abcdef');
  -- 28 four-letter + 1 five-letter + 1 seven-letter, in that order.
  syn_words text[] := array[
    'bead','beef','face','fade','cage','cafe','deaf','aged',
    'bade','feed','edge','abed','gabe','babe','dade','abef',
    'abeg','abce','acef','aceg','adef','adeg','afeg','bcef',
    'bceg','bdef','bdeg','bfeg',
    'faced',
    'abcdefg'
  ];
  w text;
  pt int;
  is_pang bool;
  total int := 0;
begin
  foreach w in array syn_words loop
    is_pang := (length(w) = 7);
    pt := case
            when length(w) = 4 then 1
            when is_pang then length(w) + 10  -- 7 + 10 pangram bonus
            else length(w)                    -- 5+: length-based
          end;
    scoring := scoring || jsonb_build_array(
      jsonb_build_object('word', w, 'points', pt, 'is_pangram', is_pang)
    );
    total := total + pt;
  end loop;
  return jsonb_build_object(
    'outer_letters', 'abcdfg',
    'center_letter', 'e',
    'total_score',   total,
    'total_words',   jsonb_array_length(scoring),
    'scoring_words', scoring,
    'legal_words',   legal
  );
end;
$$;

-- Default setup: coop, no timer. Tests that need a specific
-- mode or timer override fields via jsonb concatenation:
--   pg_temp.freebee_setup() || '{"mode": "compete", "target_rank": 3}'::jsonb

create function pg_temp.freebee_setup()
returns jsonb
language sql
as $$
  select jsonb_build_object(
    'mode',  'coop',
    'timer', jsonb_build_object('kind', 'none')
  );
$$;
